<?xml version="1.0" encoding="utf-8"?>
<!--
    Web.config - Application configuration file for FunWithVisualStudio
    A290/A590 Web Interface Design - Homework Project 2
    Configures ASP.NET settings including theme and compilation options.
-->
<configuration>
    <system.web>
        <compilation debug="true" targetFramework="4.8" />
        <httpRuntime targetFramework="4.8" />
        <!-- Apply the Basic theme site-wide -->
        <pages theme="Basic" styleSheetTheme="Basic" />
    </system.web>
</configuration>
